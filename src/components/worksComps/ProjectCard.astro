---
import type { Project } from "../../data/projects";

interface Props {
    project: Project;
    index: number;
}

const { project, index } = Astro.props;
---

<article
    class="group relative project-card"
    data-category={project.category}
    style={`animation-delay: ${index * 100}ms;`}
>
    <div
        class={`absolute -inset-2 ${project.shadow} rounded-none transform ${
            index % 2 === 0
                ? "rotate-2 group-hover:rotate-3"
                : "-rotate-2 group-hover:-rotate-3"
        } transition-transform opacity-100 border-2 border-transparent`}
    >
    </div>

    <div
        class="relative h-full flex flex-col border-4 border-black dark:border-white bg-white dark:bg-[#192233] shadow-neo-lg hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300 z-10"
    >
        <!-- Image container -->
        <div
            class="h-56 w-full border-b-4 border-black dark:border-white relative overflow-hidden bg-slate-100 dark:bg-slate-800 flex items-center justify-center"
        >
            {
                project.image ? (
                    <div
                        class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
                        style={`background-image: url('${project.image}')`}
                    />
                ) : (
                    <div class="absolute inset-0 pattern-dots transition-transform duration-700 group-hover:scale-110 opacity-50" />
                )
            }
            <div
                class={`absolute top-4 right-4 ${project.accent} ${
                    project.accent.includes("white") ||
                    project.accent.includes("EBFF00") ||
                    project.accent.includes("00FFCC")
                        ? "text-black"
                        : "text-white"
                } text-xs font-bold px-3 py-1 border-2 border-black dark:border-white shadow-neo-sm z-20`}
            >
                {project.category}
            </div>
        </div>

        <!-- Content -->
        <div class="p-6 flex flex-col flex-grow justify-between">
            <div>
                <h3
                    class="text-2xl font-black text-black dark:text-white mb-3 uppercase tracking-tight line-clamp-1 group-hover:text-[#FF0099] transition-colors"
                >
                    {project.title}
                </h3>
                <p
                    class="text-slate-600 dark:text-slate-300 font-medium mb-6 text-base leading-relaxed line-clamp-3"
                >
                    {project.description}
                </p>
            </div>

            <div>
                <div class="flex flex-wrap gap-2 mb-6">
                    {
                        project.tags.map((tag) => (
                            <span class="px-2 py-1 border-2 border-black dark:border-slate-400 text-xs font-bold text-black dark:text-white bg-transparent">
                                {tag}
                            </span>
                        ))
                    }
                </div>

                <div class="flex gap-3 mt-auto">
                    {
                        project.isUnderDevelopment ? (
                            <div class="flex-1 bg-slate-200 dark:bg-slate-700 text-slate-500 dark:text-slate-400 py-2 text-center font-bold border-2 border-dashed border-slate-400 dark:border-slate-500 text-sm uppercase flex items-center justify-center gap-1 cursor-not-allowed">
                                DEV{" "}
                                <span class="material-symbols-outlined text-[16px]">
                                    lock
                                </span>
                            </div>
                        ) : (
                            <a
                                href={project.link}
                                class="flex-1 bg-black dark:bg-white text-white dark:text-black py-2 text-center font-bold border-2 border-transparent hover:bg-transparent hover:text-black dark:hover:text-white hover:border-black dark:hover:border-white transition-colors text-sm uppercase flex items-center justify-center gap-1 group/btn"
                            >
                                Visit{" "}
                                <span class="material-symbols-outlined text-[16px] group-hover/btn:translate-x-1 group-hover/btn:-translate-y-1 transition-transform">
                                    arrow_outward
                                </span>
                            </a>
                        )
                    }
                    <a
                        href={project.repo}
                        class="px-3 py-2 bg-transparent text-black dark:text-white border-2 border-black dark:border-white hover:bg-[#EBFF00] hover:text-black hover:border-black transition-colors"
                        title="Source Code"
                    >
                        <span class="material-symbols-outlined text-[18px]"
                            >code</span
                        >
                    </a>
                </div>
            </div>
        </div>
    </div>
</article>

<style>
    /* CSS Patterns & Animations */
    .pattern-dots {
        background-image: radial-gradient(#000 1px, transparent 1px);
        background-size: 20px 20px;
    }
    :global(.dark) .pattern-dots {
        background-image: radial-gradient(#fff 1px, transparent 1px);
    }

    .project-card {
        animation: fadeUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
