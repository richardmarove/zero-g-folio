---
---

<nav
    class="sticky top-0 z-50 w-full border-b-4 border-black dark:border-white bg-gray-300 dark:bg-gray-800 px-6 py-4"
>
    <div class="mx-auto max-w-[1440px] flex items-center justify-between">
        <a
            href="/"
            class="flex items-center gap-2 md:gap-3 hover:opacity-80 transition-opacity"
        >
            <div
                class="bg-black text-white p-1 shadow-neo-sm border-2 border-black dark:bg-white dark:text-black dark:border-white transform -rotate-2"
            >
                <span
                    class="material-symbols-outlined text-xl md:text-2xl font-bold"
                    >terminal</span
                >
            </div>
            <h1
                class="text-xl md:text-2xl font-bold tracking-tight text-black dark:text-white uppercase"
            >
                ricky.space
            </h1>
        </a>
        <div class="hidden md:flex items-center gap-8">
            <a
                class="text-base font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
                href="/works">WORK</a
            >
            <a
                class="text-base font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
                href="#">ABOUT</a
            >
            <a
                class="text-base font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
                href="https://drive.usercontent.google.com/download?id=1m8UHhc6Dn0CjkyfPggVBD4v1Jo4zA8mm&export=download&authuser=0&confirm=t&uuid=d405c32d-6706-4dc2-9ad8-c3dad06f73b6&at=APcXIO34FlaApThN4-zZy4m0zePc:1772492310238"
                target="_blank">CV</a
            >
            <button
                class="bg-black text-white dark:bg-white dark:text-black px-6 py-2 font-bold shadow-neo border-2 border-transparent hover:translate-y-[2px] hover:translate-x-[2px] hover:shadow-none transition-all"
            >
                CONTACT ME
            </button>
        </div>
        <button
            id="mobile-menu-btn"
            class="md:hidden p-2 border-2 border-black dark:border-white shadow-neo-sm bg-white dark:bg-black text-black dark:text-white"
        >
            <span id="mobile-menu-icon" class="material-symbols-outlined"
                >menu</span
            >
        </button>
    </div>

    <!-- Mobile Menu Container -->
    <div
        id="mobile-menu"
        class="hidden md:hidden absolute top-full left-0 w-full bg-gray-300 dark:bg-gray-800 border-b-4 border-black dark:border-white px-6 py-6 flex-col gap-6 shadow-xl"
    >
        <a
            class="text-xl font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
            href="/works">WORK</a
        >
        <a
            class="text-xl font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
            href="#">ABOUT</a
        >
        <a
            class="text-xl font-bold text-black dark:text-white hover:underline decoration-4 decoration-black dark:decoration-white underline-offset-4"
            href="https://drive.usercontent.google.com/download?id=1m8UHhc6Dn0CjkyfPggVBD4v1Jo4zA8mm&export=download&authuser=0&confirm=t&uuid=d405c32d-6706-4dc2-9ad8-c3dad06f73b6&at=APcXIO34FlaApThN4-zZy4m0zePc:1772492310238"
            target="_blank">CV</a
        >
        <button
            class="bg-black text-white dark:bg-white dark:text-black px-6 py-4 font-bold shadow-neo border-2 border-transparent w-full mt-2"
        >
            CONTACT ME
        </button>
    </div>
</nav>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    const icon = document.getElementById("mobile-menu-icon");

    btn?.addEventListener("click", () => {
        if (menu?.classList.contains("hidden")) {
            menu.classList.remove("hidden");
            menu.classList.add("flex");
            if (icon) icon.textContent = "close";
        } else {
            menu?.classList.add("hidden");
            menu?.classList.remove("flex");
            if (icon) icon.textContent = "menu";
        }
    });
</script>
