---
---

<section
    class="py-20 border-t-4 border-black dark:border-white bg-[#EBFF00] dark:bg-[#101622] relative overflow-hidden"
>
    <div
        class="absolute -right-20 -top-20 w-96 h-96 bg-white/20 rounded-full blur-3xl pointer-events-none"
    >
    </div>
    <div class="mx-auto max-w-[1200px] px-6 relative z-10">
        <div class="grid md:grid-cols-12 gap-8">
            <div class="md:col-span-5 flex flex-col gap-6">
                <div
                    class="bg-white dark:bg-[#192233] border-4 border-black dark:border-white p-8 shadow-neo-lg"
                >
                    <h2
                        class="text-4xl font-black mb-6 uppercase text-black dark:text-white"
                    >
                        The Toolkit
                    </h2>
                    <p
                        class="text-lg font-medium mb-6 text-slate-800 dark:text-slate-300"
                    >
                        I don't just write code; I craft digital solutions. My
                        stack is built for speed, scalability, and shouting from
                        the rooftops.
                    </p>
                    <ul
                        class="space-y-3 font-mono text-base font-bold text-black dark:text-white"
                    >
                        <li class="flex items-center gap-3">
                            <span
                                class="material-symbols-outlined text-[#135bec]"
                                >check_box</span
                            >
                            Frontend Architecture
                        </li>
                        <li class="flex items-center gap-3">
                            <span
                                class="material-symbols-outlined text-[#135bec]"
                                >check_box</span
                            >
                            Interactive 3D WebGL
                        </li>
                        <li class="flex items-center gap-3">
                            <span
                                class="material-symbols-outlined text-[#135bec]"
                                >check_box</span
                            >
                            Headless CMS Integration
                        </li>
                        <li class="flex items-center gap-3">
                            <span
                                class="material-symbols-outlined text-[#135bec]"
                                >check_box</span
                            >
                            Performance Optimization
                        </li>
                    </ul>
                </div>
            </div>
            <div class="md:col-span-7 grid grid-cols-2 sm:grid-cols-3 gap-4">
                <div
                    class="bg-black dark:bg-white p-4 flex flex-col items-center justify-center aspect-square border-2 border-black hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-[#EBFF00] dark:text-[#135bec] mb-2"
                        >html</span
                    >
                    <span class="font-bold text-white dark:text-black"
                        >HTML5</span
                    >
                </div>
                <div
                    class="bg-white dark:bg-[#192233] p-4 flex flex-col items-center justify-center aspect-square border-2 border-black dark:border-white hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-[#135bec] mb-2"
                        >css</span
                    >
                    <span class="font-bold text-black dark:text-white"
                        >CSS3</span
                    >
                </div>
                <div
                    class="bg-[#FF0099] p-4 flex flex-col items-center justify-center aspect-square border-2 border-black hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-white mb-2"
                        >javascript</span
                    >
                    <span class="font-bold text-white">JS/TS</span>
                </div>
                <div
                    class="bg-white dark:bg-[#192233] p-4 flex flex-col items-center justify-center aspect-square border-2 border-black dark:border-white hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-black dark:text-white mb-2"
                        >database</span
                    >
                    <span class="font-bold text-black dark:text-white">SQL</span
                    >
                </div>
                <div
                    class="bg-[#135bec] p-4 flex flex-col items-center justify-center aspect-square border-2 border-black hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-white mb-2"
                        >api</span
                    >
                    <span class="font-bold text-white">REST API</span>
                </div>
                <div
                    class="bg-white dark:bg-[#192233] p-4 flex flex-col items-center justify-center aspect-square border-2 border-black dark:border-white hover:-translate-y-1 transition-transform"
                >
                    <span
                        class="material-symbols-outlined text-4xl text-black dark:text-white mb-2"
                        >deployed_code</span
                    >
                    <span class="font-bold text-black dark:text-white"
                        >Docker</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>
