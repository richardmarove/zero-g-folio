---
---

<section class="relative border-b-4 border-black dark:border-white">
    <div
        class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/diagmonds-light.png')] opacity-10 pointer-events-none"
    >
    </div>
    <div class="mx-auto max-w-[1440px] grid md:grid-cols-2 min-h-[600px]">
        <div
            class="p-8 md:p-16 flex flex-col justify-center border-b-4 md:border-b-0 md:border-r-4 border-black dark:border-white bg-[#FF0099] dark:bg-[#111722]"
        >
            <div
                class="inline-block w-fit bg-black text-[#EBFF00] px-3 py-1 mb-6 font-bold text-sm uppercase tracking-widest transform -rotate-1 shadow-neo-white dark:shadow-neo border-2 border-white dark:border-[#EBFF00]"
            >
                Available for hire
            </div>
            <h1
                class="text-5xl md:text-6xl lg:text-8xl font-black leading-[0.9] text-white tracking-tighter mb-8 drop-shadow-[4px_4px_0px_rgba(0,0,0,1)]"
            >
                RICKY<br />
                <span class="text-outline">ALDIANSYAH</span><br />
                MAROVE
            </h1>
            <p
                class="text-xl md:text-2xl font-medium text-white max-w-lg mb-10 border-l-4 border-black pl-4 py-2 bg-black/20"
            >
                Software engineer specializing in front-end development and
                telling people how Linux is better than Windows.
            </p>
            <div class="flex flex-col sm:flex-row flex-wrap gap-4">
                <a
                    href="/works"
                    class="bg-[#EBFF00] text-black px-8 py-4 text-lg font-black border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_#ffffff] hover:translate-y-[4px] hover:translate-x-[4px] hover:shadow-none transition-all uppercase inline-block text-center"
                >
                    View My Work
                </a>
                <button
                    class="bg-white text-black px-8 py-4 text-lg font-black border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] dark:shadow-[8px_8px_0px_0px_#ffffff] hover:translate-y-[4px] hover:translate-x-[4px] hover:shadow-none transition-all uppercase flex items-center justify-center gap-2"
                >
                    <span>Resume</span>
                    <span class="material-symbols-outlined text-xl"
                        >download</span
                    >
                </button>
            </div>
        </div>
        <div
            class="relative flex items-center justify-center p-8 bg-[#EBFF00] dark:bg-[#232f48] overflow-hidden group"
        >
            <div
                class="absolute top-4 md:top-10 right-4 md:right-10 w-20 h-20 md:w-32 md:h-32 bg-[#FF0099] rounded-full border-4 border-black z-0"
            >
            </div>
            <div
                class="absolute bottom-10 md:bottom-20 left-4 md:left-10 w-16 h-16 md:w-24 md:h-24 bg-[#135bec] transform rotate-45 border-4 border-black z-0"
            >
            </div>
            <div
                class="relative z-10 w-full max-w-md aspect-square bg-white border-4 border-black shadow-neo-lg transform group-hover:rotate-2 transition-transform duration-300"
            >
                <div
                    class="absolute inset-0 bg-[url('/johanus.png')] bg-cover bg-center contrast-125"
                    data-alt="Johanus portrait"
                >
                </div>
                <div
                    class="absolute bottom-0 left-0 right-0 bg-black p-4 text-white border-t-4 border-black"
                >
                    <div class="flex justify-between items-center">
                        <span class="font-mono text-sm">RENDER_001.GLB</span>
                        <div class="flex gap-2">
                            <div
                                class="w-3 h-3 rounded-full bg-red-500 border border-white"
                            >
                            </div>
                            <div
                                class="w-3 h-3 rounded-full bg-yellow-500 border border-white"
                            >
                            </div>
                            <div
                                class="w-3 h-3 rounded-full bg-green-500 border border-white"
                            >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
