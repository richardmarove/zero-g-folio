---
---

<section class="py-20 px-6 bg-background-light dark:bg-background-dark">
    <div class="mx-auto max-w-[1200px]">
        <div
            class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6"
        >
            <div>
                <h2
                    class="text-5xl md:text-7xl font-black text-black dark:text-white mb-2 uppercase tracking-tighter"
                >
                    Featured<br />Projects
                </h2>
                <div
                    class="h-4 w-32 bg-[#FF0099] border-2 border-black dark:border-white shadow-neo-sm"
                >
                </div>
            </div>
            <p
                class="text-xl text-slate-700 dark:text-slate-300 max-w-sm font-medium"
            >
                Selected works of mine that I'm proud of and showcases my skills
            </p>
        </div>
        <div class="grid grid-cols-1 gap-16">
            <article class="group relative">
                <div
                    class="absolute -inset-2 bg-black dark:bg-white rounded-none transform rotate-1 group-hover:rotate-2 transition-transform opacity-100 border-2 border-transparent"
                >
                </div>
                <div
                    class="relative grid md:grid-cols-2 gap-0 border-4 border-black dark:border-white bg-white dark:bg-[#192233] shadow-neo-lg hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300"
                >
                    <div
                        class="h-64 md:h-auto min-h-[300px] border-b-4 md:border-b-0 md:border-r-4 border-black dark:border-white relative overflow-hidden"
                    >
                        <div
                            class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
                            data-alt="Neon cyberpunk retro computer setup"
                        >
                        </div>
                        <div
                            class="absolute top-4 left-4 bg-[#EBFF00] text-black text-xs font-bold px-2 py-1 border-2 border-black shadow-neo-sm"
                        >
                            ECOMMERCE
                        </div>
                    </div>
                    <div class="p-8 flex flex-col justify-between">
                        <div>
                            <h3
                                class="text-3xl font-black text-black dark:text-white mb-2 uppercase"
                            >
                                Neon Cyberpunk Store
                            </h3>
                            <p
                                class="text-slate-600 dark:text-slate-300 font-medium mb-6 text-lg leading-relaxed"
                            >
                                An immersive e-commerce platform featuring WebGL
                                product views, glitch effects, and a custom cart
                                system.
                            </p>
                            <div class="flex flex-wrap gap-2 mb-8">
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >React</span
                                >
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >Three.js</span
                                >
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >Stripe</span
                                >
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <a
                                class="flex-1 bg-[#EBFF00] text-black text-center py-3 font-bold border-2 border-black shadow-[4px_4px_0px_0px_#000000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all flex items-center justify-center gap-2"
                                href="#"
                            >
                                VISIT SITE <span
                                    class="material-symbols-outlined text-sm"
                                    >arrow_outward</span
                                >
                            </a>
                            <a
                                class="px-4 py-3 bg-white dark:bg-transparent text-black dark:text-white border-2 border-black dark:border-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                href="#"
                                title="View Code"
                            >
                                <span class="material-symbols-outlined"
                                    >code</span
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </article>
            <article class="group relative">
                <div
                    class="absolute -inset-2 bg-[#FF0099] rounded-none transform -rotate-1 group-hover:-rotate-2 transition-transform opacity-100 border-2 border-black dark:border-transparent"
                >
                </div>
                <div
                    class="relative grid md:grid-cols-2 gap-0 border-4 border-black dark:border-white bg-white dark:bg-[#192233] shadow-neo-lg hover:shadow-none hover:translate-x-2 hover:translate-y-2 transition-all duration-300"
                >
                    <div
                        class="h-64 md:h-auto min-h-[300px] border-b-4 md:border-b-0 md:border-r-4 border-black dark:border-white relative overflow-hidden md:order-2"
                    >
                        <div
                            class="absolute inset-0 bg-[url('/project-overlord.png')] bg-cover bg-center transition-transform duration-500 group-hover:scale-110"
                            data-alt="Project Overlord dashboard screenshot"
                        >
                        </div>
                        <div
                            class="absolute top-4 right-4 bg-[#135bec] text-white text-xs font-bold px-2 py-1 border-2 border-white shadow-neo-sm"
                        >
                            ANALYTICS
                        </div>
                    </div>
                    <div class="p-8 flex flex-col justify-between md:order-1">
                        <div>
                            <h3
                                class="text-3xl font-black text-black dark:text-white mb-2 uppercase"
                            >
                                project-overlord
                            </h3>
                            <p
                                class="text-slate-600 dark:text-slate-300 font-medium mb-6 text-lg leading-relaxed"
                            >
                                My own personal CMS that I built for myself to
                                rant about my life and politics.
                            </p>
                            <div class="flex flex-wrap gap-2 mb-8">
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >Astro</span
                                >
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >Tailwind</span
                                >
                                <span
                                    class="px-3 py-1 border-2 border-black dark:border-slate-400 text-sm font-bold text-black dark:text-white rounded-full"
                                    >Supabase</span
                                >
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <a
                                class="flex-1 bg-[#EBFF00] text-black text-center py-3 font-bold border-2 border-black shadow-[4px_4px_0px_0px_#000000] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all flex items-center justify-center gap-2"
                                href="#"
                            >
                                VISIT SITE <span
                                    class="material-symbols-outlined text-sm"
                                    >arrow_outward</span
                                >
                            </a>
                            <a
                                class="px-4 py-3 bg-white dark:bg-transparent text-black dark:text-white border-2 border-black dark:border-white hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors"
                                href="#"
                                title="View Code"
                            >
                                <span class="material-symbols-outlined"
                                    >code</span
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </article>
        </div>
        <div class="mt-16 text-center">
            <button
                class="bg-white dark:bg-transparent text-black dark:text-white px-8 py-3 text-lg font-bold border-4 border-black dark:border-white hover:bg-black hover:text-white dark:hover:bg-white dark:hover:text-black transition-colors uppercase"
            >
                View Full Archive
            </button>
        </div>
    </div>
</section>
