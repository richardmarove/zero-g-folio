---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { toolkitCategories, type ToolkitCategory } from "../data/toolkits";

const accentClasses: Record<
    ToolkitCategory["accent"],
    { panel: string; label: string; chip: string }
> = {
    yellow: {
        panel: "bg-[#EBFF00] dark:bg-[#1c2434]",
        label: "bg-black text-[#EBFF00] border-black dark:border-white",
        chip: "bg-white dark:bg-[#101622] text-black dark:text-white border-black dark:border-white",
    },
    pink: {
        panel: "bg-[#FF0099] dark:bg-[#2a1d37]",
        label: "bg-[#EBFF00] text-black border-black dark:border-white",
        chip: "bg-white dark:bg-[#101622] text-black dark:text-white border-black dark:border-white",
    },
    blue: {
        panel: "bg-[#135bec] dark:bg-[#172947]",
        label: "bg-white text-black border-black dark:border-white",
        chip: "bg-[#EBFF00] dark:bg-[#101622] text-black dark:text-white border-black dark:border-white",
    },
    black: {
        panel: "bg-black dark:bg-black",
        label: "bg-[#EBFF00] text-black border-black dark:border-white",
        chip: "bg-white text-black border-black dark:border-white",
    },
    white: {
        panel: "bg-white dark:bg-[#192233]",
        label: "bg-[#135bec] text-white border-black dark:border-white",
        chip: "bg-[#EBFF00] dark:bg-[#101622] text-black dark:text-white border-black dark:border-white",
    },
};
---

<Layout title="/home/ricky/toolkits">
    <Navbar />

    <main
        class="relative flex-grow min-h-screen pt-32 pb-20 px-6 bg-background-light dark:bg-background-dark overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/diagmonds-light.png')] opacity-10 pointer-events-none"
        >
        </div>
        <div
            class="absolute -right-32 -top-24 w-[500px] h-[500px] bg-[#FF0099]/15 dark:bg-[#135bec]/20 rounded-full blur-3xl pointer-events-none"
        >
        </div>
        <div
            class="absolute -left-28 bottom-0 w-[420px] h-[420px] bg-[#EBFF00]/20 dark:bg-[#EBFF00]/10 rounded-full blur-3xl pointer-events-none"
        >
        </div>

        <div class="relative z-10 mx-auto max-w-[1440px]">
            <header class="mb-14 md:mb-18">
                <h1
                    class="text-6xl md:text-8xl font-black text-black dark:text-white uppercase tracking-tighter leading-[0.9]"
                >
                    TOOLKITS<br /><span class="text-[#FF0099] dark:text-[#EBFF00]"
                        >ARCHIVE</span
                    >
                </h1>
                <div
                    class="mt-5 h-4 w-52 bg-[#EBFF00] border-2 border-black dark:border-white shadow-neo-sm"
                >
                </div>
                <p
                    class="mt-8 max-w-3xl text-lg md:text-2xl font-medium text-slate-700 dark:text-slate-300 border-l-8 border-[#135bec] pl-4"
                >
                    The full hardware + software setup behind how I design,
                    build, debug, and ship projects.
                </p>
            </header>

            <section class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                {
                    toolkitCategories.map((category, index) => {
                        const accent = accentClasses[category.accent];
                        const rotateClass =
                            index % 2 === 0 ? "md:-rotate-1" : "md:rotate-1";

                        return (
                            <article class="group relative">
                                <div
                                    class={`absolute -inset-2 border-4 border-black dark:border-white ${index % 3 === 0 ? "bg-[#FF0099]" : index % 3 === 1 ? "bg-[#EBFF00]" : "bg-[#135bec]"} ${index % 2 === 0 ? "rotate-1" : "-rotate-1"} transition-transform group-hover:rotate-0`}
                                >
                                </div>
                                <div
                                    class={`relative h-full border-4 border-black dark:border-white p-6 md:p-8 shadow-[10px_10px_0px_0px_rgba(0,0,0,1)] dark:shadow-[10px_10px_0px_0px_#ffffff] transition-all group-hover:translate-x-2 group-hover:translate-y-2 group-hover:shadow-none ${accent.panel} ${rotateClass}`}
                                >
                                    <div
                                        class={`inline-block px-3 py-1 border-2 text-sm uppercase tracking-widest font-black ${accent.label}`}
                                    >
                                        {category.title}
                                    </div>

                                    <ul class="mt-6 flex flex-wrap gap-3">
                                        {category.items.map((item) => (
                                            <li
                                                class={`px-3 py-2 border-2 font-bold text-sm md:text-base leading-tight shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] dark:shadow-[4px_4px_0px_0px_#ffffff] ${accent.chip}`}
                                            >
                                                {item.name}
                                                {item.note && (
                                                    <span class="ml-2 inline-block px-2 py-0.5 text-xs font-black uppercase bg-black text-[#EBFF00] border border-[#EBFF00]">
                                                        {item.note}
                                                    </span>
                                                )}
                                            </li>
                                        ))}
                                    </ul>
                                </div>
                            </article>
                        );
                    })
                }
            </section>

            <div class="mt-14">
                <a
                    href="/"
                    class="inline-flex items-center gap-3 bg-black text-white dark:bg-white dark:text-black px-6 py-3 text-base md:text-lg font-black border-4 border-black dark:border-white shadow-[8px_8px_0px_0px_#FF0099] dark:shadow-[8px_8px_0px_0px_#FF0099] hover:translate-x-2 hover:translate-y-2 hover:shadow-none transition-all uppercase"
                >
                    <span class="material-symbols-outlined text-xl"
                        >arrow_back</span
                    >
                    <span>Back To Home</span>
                </a>
            </div>
        </div>
    </main>

    <Footer />
</Layout>
